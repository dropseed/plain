<section class="tasks">
  <header>
    <h1>Tasks for {owner.name}</h1>
    <p class="meta">{len(tasks)} task{"s" if len(tasks) != 1 else ""} · {done_count} done</p>
  </header>
  <div :if={alert} class="alert" data-severity={alert.severity if alert else ""}>
    <strong>{alert.title if alert else ""}</strong>
    <span>{alert.body if alert else ""}</span>
  </div>
  <ul class="task-list" data-owner={owner.id}>
    <li :for={task in tasks} class="task" data-id={task.id} data-done={task.done}>
      <a href="/tasks/{task.id}/" class="title">{task.title}</a>
      <span class="due">{task.due}</span>
      <span :if={task.tags} class="tags"><span :for={tag in task.tags} class="tag">{tag}</span></span>
    </li>
  </ul>
  <p :if={not tasks} class="empty">No tasks yet. Add one above.</p>
</section>
