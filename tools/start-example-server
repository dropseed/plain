#!/bin/bash -e

# Start the example server on a random port for testing/benchmarking.
# Exports PORT and SERVER_PID. Sets up cleanup trap.
#
# Set SERVER_LOG to an absolute file path (e.g. a mktemp file) before
# sourcing to capture server output (default: discarded). The file is
# removed by the cleanup trap when the caller exits, and on a failed
# startup the captured output is printed first.
#
# Usage:
#   source tools/start-example-server [extra server args...]

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Resolve the output target before example/.env is sourced below so a
# SERVER_LOG entry there can't redirect it.
SERVER_OUT="${SERVER_LOG:-/dev/null}"

PORT=$(uv run python -c "import socket; s=socket.socket(); s.bind(('127.0.0.1',0)); print(s.getsockname()[1]); s.close()")

cd "$REPO_ROOT/example"

if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

export PYTHONPATH="$REPO_ROOT/example${PYTHONPATH:+:$PYTHONPATH}"

uv run plain server --bind "127.0.0.1:$PORT" --workers 1 "$@" &>"$SERVER_OUT" &
SERVER_PID=$!
cd "$REPO_ROOT"

# The server may already be dead at cleanup time (e.g. a shutdown test
# stopped it), so the kill/wait must not fail the caller under -e.
cleanup() {
    kill "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true
    if [ "$SERVER_OUT" != /dev/null ]; then
        rm -f "$SERVER_OUT"
    fi
}
trap cleanup EXIT

for i in $(seq 1 30); do
    if ! kill -0 "$SERVER_PID" 2>/dev/null; then
        echo "Server process died before accepting connections" >&2
        if [ "$SERVER_OUT" != /dev/null ]; then
            cat "$SERVER_OUT" >&2
        fi
        exit 1
    fi
    if nc -z 127.0.0.1 "$PORT" 2>/dev/null; then
        break
    fi
    sleep 0.5
done
