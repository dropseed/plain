#!/bin/bash -e

# Run HTTP/2 worker behavior tests against the Plain server.
#
# Usage:
#   ./tools/h2-worker-test                     # starts example server automatically
#   ./tools/h2-worker-test host:port           # test against an already-running TLS server

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

if [ $# -gt 0 ] && [[ "$1" == *:* ]]; then
    TARGET="$1"
    shift
    uv run python "$REPO_ROOT/tools/h2-worker-test.py" "$TARGET" "$@"
    exit $?
fi

# Generate a temporary self-signed certificate for TLS
CERTDIR=$(mktemp -d)
trap 'rm -rf "$CERTDIR"' EXIT

openssl req -x509 -newkey rsa:2048 -keyout "$CERTDIR/key.pem" -out "$CERTDIR/cert.pem" \
    -days 1 -nodes -subj "/CN=localhost" 2>/dev/null

source "$(dirname "$0")/start-example-server" \
    --certfile "$CERTDIR/cert.pem" --keyfile "$CERTDIR/key.pem"

uv run python "$REPO_ROOT/tools/h2-worker-test.py" "127.0.0.1:$PORT" "$@"
