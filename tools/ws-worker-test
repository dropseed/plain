#!/bin/bash -e

# Run WebSocket worker behavior tests against the Plain example app.
#
# Usage:
#   ./tools/ws-worker-test                     # starts example server automatically
#   ./tools/ws-worker-test host:port           # test against an already-running server

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

if [ $# -gt 0 ] && [[ "$1" == *:* ]]; then
    TARGET="$1"
    shift
    uv run python "$REPO_ROOT/tools/ws-worker-test.py" "$TARGET" "$@"
    exit $?
fi

# Disable HTTPS redirect — WebSocket tests use plain HTTP
export PLAIN_HTTPS_REDIRECT_ENABLED=false

source "$(dirname "$0")/start-example-server"

uv run python "$REPO_ROOT/tools/ws-worker-test.py" "127.0.0.1:$PORT" "$@"
