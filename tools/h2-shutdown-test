#!/bin/bash -e

# H2 graceful shutdown test: SIGTERM the example server (TLS+h2) and assert
# open connections get GOAWAY and close, the master exits 0, and nothing is
# logged at ERROR.
#
# Usage:
#   ./tools/h2-shutdown-test

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

SERVER_LOG="$(mktemp)"
CERTDIR="$(mktemp -d)"

# Cover failures before start-example-server installs its own trap; that
# trap owns kill/wait and log removal for the rest of the run.
trap 'rm -f "$SERVER_LOG"; rm -rf "$CERTDIR"' EXIT

openssl req -x509 -newkey rsa:2048 -keyout "$CERTDIR/key.pem" -out "$CERTDIR/cert.pem" \
    -days 1 -nodes -subj "/CN=localhost" 2>/dev/null

source "$(dirname "$0")/start-example-server" \
    --certfile "$CERTDIR/cert.pem" --keyfile "$CERTDIR/key.pem"

# From here on the sourced cleanup owns the server and log; add the certs.
cleanup_all() {
    cleanup || true
    rm -rf "$CERTDIR"
}
trap cleanup_all EXIT

uv run python "$REPO_ROOT/tools/h2-shutdown-test.py" "127.0.0.1:$PORT" \
    --pid "$SERVER_PID" --log "$SERVER_LOG"

# The test SIGTERMed the server; a graceful shutdown must exit 0.
if ! wait "$SERVER_PID"; then
    echo "Server exited non-zero after graceful SIGTERM" >&2
    exit 1
fi
