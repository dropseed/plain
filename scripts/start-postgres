#!/bin/bash -e

# Start a local PostgreSQL instance for development/testing.
# Sets DATABASE_URL if not already set.
#
# Tries in order:
#   1. Already-running PostgreSQL on localhost:5432
#   2. Debian/Ubuntu pg_ctlcluster (e.g. system-installed PostgreSQL in CI/cloud)
#   3. Docker container
#
# Usage:
#   source scripts/start-postgres [db_name]
#
# The optional db_name argument defaults to "plain_dev".

DB_NAME="${1:-plain_dev}"

if [ -z "$DATABASE_URL" ]; then
  export DATABASE_URL="postgres://postgres:postgres@localhost:5432/$DB_NAME"

  if ! pg_isready -h localhost -p 5432 -U postgres >/dev/null 2>&1; then

    # --- Try local cluster first (common in CI / cloud environments) ---
    if command -v pg_lsclusters >/dev/null 2>&1; then
      read -r _pg_ver _pg_cluster _ _pg_status _ <<< "$(pg_lsclusters -h 2>/dev/null | head -1)"
      if [ -n "$_pg_ver" ] && [ "$_pg_status" != "online" ]; then
        echo "Starting local PostgreSQL ${_pg_ver}/${_pg_cluster} cluster..."
        pg_ctlcluster "$_pg_ver" "$_pg_cluster" start 2>/dev/null || true
        # Give the cluster a moment to accept connections before falling through to Docker
        for _ in {1..5}; do
          pg_isready -h localhost -p 5432 -U postgres >/dev/null 2>&1 && break
          sleep 1
        done
      fi
      # Set password for the postgres user so our DATABASE_URL works
      if pg_isready -h localhost -p 5432 -U postgres >/dev/null 2>&1; then
        su -c "psql -c \"ALTER USER postgres PASSWORD 'postgres';\"" postgres >/dev/null 2>&1 || true
      fi
      unset _pg_ver _pg_cluster _pg_status
    fi

    # --- Fall back to Docker if local PostgreSQL didn't work ---
    if ! pg_isready -h localhost -p 5432 -U postgres >/dev/null 2>&1; then
      echo "Starting PostgreSQL via Docker..."
      if docker start plain-postgres-dev >/dev/null 2>&1; then
        true
      else
        docker run -d --name plain-postgres-dev \
          -e POSTGRES_PASSWORD=postgres \
          -e POSTGRES_DB="$DB_NAME" \
          -p 5432:5432 \
          postgres:16 >/dev/null 2>&1
      fi
    fi

    # Wait for PostgreSQL to be ready
    echo "Waiting for PostgreSQL to be ready..."
    for i in {1..30}; do
      if pg_isready -h localhost -p 5432 -U postgres >/dev/null 2>&1; then
        break
      fi
      sleep 1
    done

    if ! pg_isready -h localhost -p 5432 -U postgres >/dev/null 2>&1; then
      echo "ERROR: PostgreSQL failed to start."
      exit 1
    fi
  fi
fi
