#!/bin/bash -e

# Make a Postgres database available and export PLAIN_POSTGRES_URL.
#
# This defers to plain.dev's managed Postgres — the same thing any app gets
# from `plain dev` — so the repo uses the feature it ships. That gives a
# container per project, a database per checkout (so parallel worktrees don't
# collide), and a fallback to a local Postgres on 5432 when Docker isn't
# available.
#
# Usage:
#   source scripts/start-postgres
#
# Setting PLAIN_POSTGRES_URL yourself skips all of this, which is what CI does.

if [ -z "$PLAIN_POSTGRES_URL" ]; then
  PLAIN_POSTGRES_URL="$(cd example && uv run plain db url)"
  export PLAIN_POSTGRES_URL
fi
