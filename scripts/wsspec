#!/bin/bash -e

# Run WebSocket conformance tests against the Plain server (RFC 6455).
#
# Usage:
#   ./scripts/wsspec                          # starts example server automatically
#   ./scripts/wsspec host:port                # test against an already-running server
#   ./scripts/wsspec --strict                 # strict mode (show error details)

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

TARGET=""
WSSPEC_ARGS=()
for arg in "$@"; do
    if [ -z "$TARGET" ] && [[ "$arg" == *:* ]]; then
        TARGET="$arg"
    else
        WSSPEC_ARGS+=("$arg")
    fi
done

if [ -n "$TARGET" ]; then
    uv run python "$REPO_ROOT/scripts/wsspec.py" "${WSSPEC_ARGS[@]}" "$TARGET"
    exit $?
fi

# Start the example server on a random port
PORT=$(uv run python -c "import socket; s=socket.socket(); s.bind(('127.0.0.1',0)); print(s.getsockname()[1]); s.close()")

cd "$REPO_ROOT/example"

# Load .env for database config etc.
if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

export PYTHONPATH="$REPO_ROOT/example${PYTHONPATH:+:$PYTHONPATH}"

uv run plain server --bind "127.0.0.1:$PORT" --workers 1 &>/dev/null &
SERVER_PID=$!
cd "$REPO_ROOT"

cleanup() {
    kill "$SERVER_PID" 2>/dev/null
    wait "$SERVER_PID" 2>/dev/null
}
trap cleanup EXIT

# Wait for server to accept connections
for i in $(seq 1 30); do
    if ! kill -0 "$SERVER_PID" 2>/dev/null; then
        echo "Server process died before accepting connections" >&2
        exit 1
    fi
    if nc -z 127.0.0.1 "$PORT" 2>/dev/null; then
        break
    fi
    sleep 0.5
done

uv run python "$REPO_ROOT/scripts/wsspec.py" "${WSSPEC_ARGS[@]}" "127.0.0.1:$PORT"
