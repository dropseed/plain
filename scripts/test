#!/bin/bash -e

# Run the test-suite for each first-party package as well as the demo projects.
#
#  • Installs psycopg database driver wheel on-demand.

# ---------------------------------------------------------------------------
# CLI option parsing
# ---------------------------------------------------------------------------
# A single package name may be supplied to limit the run; otherwise test all
# first-party packages in a deterministic order.
#
# Flags:
#   --server       Include server behavior and conformance tests
#   --python 3.14  Run with a specific Python version (sets UV_PYTHON)
ALL_PACKAGES="$(cat <<EOF
plain
plain-postgres
plain-sessions
plain-jobs
plain-flags
plain-admin
plain-oauth
plain-oauth-provider
plain-auth
plain-api
plain-elements
plain-htmx
plain-email
plain-pages
plain-mcp
EOF
)"

run_server=false
remaining=()
while [ $# -gt 0 ]; do
  case "$1" in
    --server) run_server=true; shift ;;
    --python) [ -z "${2:-}" ] && echo "Error: --python requires a version argument" >&2 && exit 1; export UV_PYTHON="$2"; shift 2 ;;
    *) remaining+=("$1"); shift ;;
  esac
done
set -- "${remaining[@]}"

packages=$ALL_PACKAGES
if [ $# -gt 0 ] && printf '%s\n' $ALL_PACKAGES | grep -x "$1" >/dev/null; then
  packages=$1
  shift
fi

# Convenience for bold headings.
bold() { printf '\033[1m%s\033[0m\n' "$1"; }

# ---------------------------------------------------------------------------
# Database URL (PostgreSQL required)
# ---------------------------------------------------------------------------
# Use a unique DB name per checkout so parallel worktrees don't collide.
_repo_dir=$(basename "$(git rev-parse --show-toplevel)")
_db_suffix=$(echo "$_repo_dir" | tr '-' '_')
source scripts/start-postgres "plain_tests_${_db_suffix}"

echo "Using DATABASE_URL: $DATABASE_URL"

# PostgreSQL driver
WITH="--with psycopg[binary]"

if [ -n "$UV_PYTHON" ]; then
  bold "Python: $UV_PYTHON"
fi
bold "Packages to test: $packages"

for package in $packages; do
  echo
  bold "Testing $package"

  cd "$package/tests"

  set -x
  uv run \
    --isolated \
    --package "$package" \
    $WITH \
    python -m pytest "$@"
  set +x

  cd ../..

  # MCP conformance suite (external, Node.js-based) — runs after plain-mcp
  # unit tests. Gracefully skips if `npx` isn't available.
  if [ "$package" = "plain-mcp" ]; then
    echo
    bold "Running MCP conformance suite for plain-mcp"
    plain-mcp/tests/conformance/run
  fi
done

# Example project (smoke-tests only)
echo
bold "Testing example"
cd "example"
uv run --isolated $WITH python -m pytest "$@"
cd ..

if [ "$run_server" = false ]; then
  echo
  bold "Skipping server tests (use --server to include)"
else
  # Server worker behavior tests
  echo
  bold "Running server-worker-test"
  tools/server-worker-test

  # HTTP/2 worker behavior tests
  echo
  bold "Running h2-worker-test"
  tools/h2-worker-test

  # HTTP/1.1 conformance tests (h1spec)
  echo
  bold "Running h1spec"
  tools/h1spec

  # HTTP/2 conformance tests (h2spec, requires: brew install h2spec)
  echo
  if command -v h2spec &>/dev/null; then
    bold "Running h2spec"
    tools/h2spec
  else
    bold "Skipping h2spec (not installed — brew install h2spec)"
  fi
fi

