#!/bin/sh -e
BOLD=$(tput bold)
NORMAL=$(tput sgr0)

# Disable cloud OTLP export for every `plain` command in this script (tests,
# preflight, etc.). See scripts/test for the full rationale.
export PLAIN_CLOUD_EXPORT_ENABLED=false

echo "${BOLD}Checking formatting and linting${NORMAL}"
./scripts/fix --check

# Skip tests, type checks, and preflight if only .md files are being committed
STAGED_CODE=$(git diff --cached --name-only | grep -v '\.md$' || true)
if [ -z "$STAGED_CODE" ]; then
    echo ""
    echo "Only .md files staged — skipping tests, type checks, and preflight."
    exit 0
fi

echo ""
echo "${BOLD}Validating type annotations${NORMAL}"
./scripts/type-validate

echo ""
echo "${BOLD}Running tests${NORMAL}"
./scripts/test

echo ""
echo "${BOLD}Running preflight in example${NORMAL}"
source scripts/start-postgres plain_example
PGPASSWORD=postgres createdb -h localhost -U postgres plain_example 2>/dev/null || true
cd example && uv run plain preflight
