<template :include="base">
<template slot="title">New task</template>
<div class="max-w-2xl mx-auto px-5 py-12">
    <template :include="components/back_link" href={url('tasks:list')} label="Back to tasks" />

    <h1 class="page-h1">New task</h1>

    <form method="post" class="mt-6 flex flex-col gap-5">
        <template :include="tasks/_form_partial" form={form} />
        <button type="submit" class="btn-primary self-start">Create</button>
    </form>
</div>
</template>
