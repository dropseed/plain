# PostgreSQL database (scripts/test and scripts/create-migrations start Docker automatically)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/plain_example

# Public tunnel URL (shown in dev server status bar)
DEV_TUNNEL_URL=https://plain-example.plaintunnel.com

# Keep tests from exporting telemetry to the real endpoint, even when
# someone runs pytest directly against the example app without going
# through scripts/test.
PLAIN_CLOUD_EXPORT_ENABLED=false
